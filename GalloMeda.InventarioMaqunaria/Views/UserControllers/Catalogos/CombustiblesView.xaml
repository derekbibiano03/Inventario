<UserControl x:Class="Inventario.Desktop.Views.UserControllers.Catalogos.CombustiblesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inventario.Desktop.Views.UserControllers.Catalogos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" 
              HorizontalAlignment="Left"
              ItemsSource="{Binding Combustibles}" 
              AutoGenerateColumns="False" 
              CanUserAddRows="False"
              HeadersVisibility="Column"
              Background="Gray"
              BorderBrush="#CCCCCC"
              BorderThickness="2"
              RowHeight="30"
              AlternatingRowBackground="#F9F9F9">

            <DataGrid.Columns>
                <DataGridTextColumn Header="No.Economico" Width="100" Binding="{Binding IdCombustible}" IsReadOnly="True"/>

                <DataGridTextColumn Header="Descripción" Width="200" Binding="{Binding DescripcionCombustible}" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
