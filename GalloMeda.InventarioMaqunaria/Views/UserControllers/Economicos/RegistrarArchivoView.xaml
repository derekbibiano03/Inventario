<UserControl x:Class="Inventario.Desktop.Views.UserControllers.Economicos.RegistrarArchivoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inventario.Desktop.Views.UserControllers.Economicos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Fila para el título -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para selección de Económico -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para selección de Archivo -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para previsualización de metadatos -->
            <RowDefinition Height="*"/>
            <!-- Fila de espacio/relleno -->
            <RowDefinition Height="Auto"/>
            <!-- Fila para botones de acción -->
        </Grid.RowDefinitions>

        <!-- Título del Formulario -->
        <TextBlock Grid.Row="0" 
                   Text="Adjuntar Documento o Imagen del Economico" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20" 
                   Foreground="#333333"/>

        <!-- Sección 1: Selección del Económico -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Buscar y Seleccionar Económico:" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5"/>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Buscar y Seleccionar Económicos (Selección Múltiple):" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5"/>

                <TextBox Text="{Binding TextoBusquedaId, UpdateSourceTrigger=PropertyChanged}" 
                     Tag="Buscar por ID..." 
                     Height="30" 
                     VerticalContentAlignment="Center" 
                     Margin="0,0,0,5"
                     Padding="5,0"/>

                <ListBox ItemsSource="{Binding EconomicosFiltrados}" 
                     Height="120" 
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                  Margin="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding IdEconomico}" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,10,0"/>
                                    <TextBlock Text=" - "/>
                                    <TextBlock Text="{Binding Descripcion}" Margin="10,0,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </StackPanel>

        <!-- Sección 2: Selección del Archivo Físico -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Documento (PDF o Imagen):" 
                       FontWeight="SemiBold" 
                       Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         Text="{Binding RutaArchivoOriginal, Mode=TwoWay}" 
                         IsReadOnly="True" 
                         Height="30" 
                         VerticalContentAlignment="Center" 
                         Background="#F5F5F5" 
                         Padding="5,0"/>

                <Button Grid.Column="1" 
                        Content="Buscar Archivo..." 
                        Command="{Binding SeleccionarArchivoCommand}" 
                        Width="120" 
                        Margin="10,0,0,0" 
                        Height="30"/>
            </Grid>
        </StackPanel>

        <!-- Sección 3: Datos que se guardarán en CatalogoArchivos (Simulación/Previsualización) -->
        <Border Grid.Row="3" 
                Background="#FAFAFA" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1" 
                CornerRadius="4" 
                Padding="15" 
                Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="Detalles del Registro a dar de Alta" 
                           FontWeight="Bold" 
                           Foreground="#555555" 
                           Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Nombre del Archivo Original -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nombre Archivo: " FontWeight="SemiBold" Margin="0,2,10,2"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding NombreArchivoOriginal}" Margin="0,2,0,2" Foreground="Blue"/>

                    <!-- Fecha de Alta automática -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Fecha Alta: " FontWeight="SemiBold" Margin="0,2,10,2"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FechaAltaActual, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Margin="0,2,0,2"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Sección 4: Botón de Guardado Final -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,20,0,0">
            <Button Content="Cancelar" 
                    Width="100" 
                    Height="35" 
                    Margin="0,0,10,0" 
                    Background="#E0E0E0" 
                    BorderBrush="{x:Null}"/>
            <Button Content="Guardar en Sistema" 
                    Command="{Binding GuardarArchivoCommand}" 
                    Width="150" 
                    Height="35" 
                    Background="#007ACC" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    BorderBrush="{x:Null}"/>
        </StackPanel>
    </Grid>
</UserControl>
