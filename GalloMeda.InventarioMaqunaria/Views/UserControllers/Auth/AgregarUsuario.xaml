<UserControl x:Class="Inventario.Desktop.Views.UserControllers.Auth.AgregarUsuario"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Inventario.Desktop.Views.UserControllers.Auth"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical" Margin="30,30,10,0">

            <TextBlock Text="Nombre de Usuario:" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBox Text="{Binding NombreUsuario, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Width="250" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Contraseña:" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBox Text="{Binding ContrasenaPlana, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Width="250" Height="30" Margin="0,0,0,10"/>

            <TextBlock Text="Tipo de Usuario:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ComboBox 
                ItemsSource="{Binding Roles}"
                DisplayMemberPath="DescripcionRol" 
                SelectedValuePath="IdRol"
                SelectedValue="{Binding IdRolSeleccionado, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                Width="250" 
                Height="30"
                HorizontalAlignment="Left"
                Margin="0,0,0,10"/>
            
            

            <TextBlock Text="* Campos obligatorios. La contraseña será encriptada automáticamente usando un algoritmo irreversible de Hash (BCrypt) antes de ser guardada en PostgreSQL." FontSize="11" Foreground="#718096" TextWrapping="Wrap"/>

            <Button 
    Content="Registrar Usuario" 
    Command="{Binding RegistrarUsuarioCommand}" 
    Width="150" 
    Height="35" 
    HorizontalAlignment="Left" 
    Background="#2B6CB0" 
    Foreground="White" 
    FontWeight="Bold" 
    Margin="0,15,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
